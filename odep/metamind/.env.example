# MetaMind Environment Configuration
# Copy to .env and customize for your environment

# Application
METAMIND_APP_ENV=development
METAMIND_DEBUG=true
METAMIND_HOST=0.0.0.0
METAMIND_PORT=8000

# Database (PostgreSQL)
METAMIND_DB__HOST=localhost
METAMIND_DB__PORT=5432
METAMIND_DB__DATABASE=metamind
METAMIND_DB__USER=metamind
METAMIND_DB__PASSWORD=metamind
METAMIND_DB__POOL_SIZE=20

# Redis
METAMIND_REDIS__HOST=localhost
METAMIND_REDIS__PORT=6379
METAMIND_REDIS__DB=0

# Trino
METAMIND_TRINO__COORDINATOR_URL=http://localhost:8080
METAMIND_TRINO__USER=metamind
METAMIND_TRINO__CATALOG=iceberg
METAMIND_TRINO__SCHEMA=default
METAMIND_TRINO__MAX_CONCURRENT=100

# Oracle (optional)
METAMIND_ORACLE__HOST=localhost
METAMIND_ORACLE__PORT=1521
METAMIND_ORACLE__SERVICE_NAME=ORCLPDB1
METAMIND_ORACLE__USER=metamind_read
METAMIND_ORACLE__PASSWORD=
METAMIND_ORACLE__MAX_SESSIONS=20
METAMIND_ORACLE__QUERY_TIMEOUT=60

# S3/MinIO
METAMIND_S3__BUCKET=metamind-data-lake
METAMIND_S3__REGION=us-east-1
METAMIND_S3__ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Cache
METAMIND_CACHE__L1_ENABLED=true
METAMIND_CACHE__L1_TTL_SECONDS=300
METAMIND_CACHE__L2_ENABLED=true
METAMIND_CACHE__L2_TTL_SECONDS=3600
METAMIND_CACHE__L2_MAX_SIZE_MB=100

# ML
METAMIND_ML__MODEL_PATH=./models
METAMIND_ML__TRAINING_ENABLED=true
METAMIND_ML__MIN_TRAINING_SAMPLES=1000

# CDC
METAMIND_CDC__KAFKA_BOOTSTRAP_SERVERS=localhost:9092
METAMIND_CDC__HEALTHY_LAG_SECONDS=300
METAMIND_CDC__WARNING_LAG_SECONDS=600

# Security
METAMIND_SECURITY__JWT_SECRET=change-me-in-production
METAMIND_SECURITY__JWT_EXPIRATION_HOURS=24
METAMIND_SECURITY__RATE_LIMIT_REQUESTS=1000

# Observability
METAMIND_OBSERVABILITY__LOG_LEVEL=INFO
METAMIND_OBSERVABILITY__METRICS_ENABLED=true
METAMIND_OBSERVABILITY__TRACING_ENABLED=true

# GPU (optional)
METAMIND_GPU__ENABLED=false
METAMIND_GPU__DEVICE_ID=0
