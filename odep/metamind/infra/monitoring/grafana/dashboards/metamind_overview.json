{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "MetaMind Platform — Operations Overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Request Metrics",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 1},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "expr": "rate(metamind_requests_total[1m])",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "title": "Requests per Second",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "ms", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}]}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 10, "x": 6, "y": 1},
      "id": 3,
      "options": {"colorMode": "background"},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(metamind_request_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, rate(metamind_request_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, rate(metamind_request_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p99", "refId": "C"}
      ],
      "title": "Latency Percentiles (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "gridPos": {"h": 8, "w": 4, "x": 16, "y": 1},
      "id": 4,
      "targets": [
        {
          "expr": "rate(metamind_requests_total{status=~\"5..\"}[5m]) / rate(metamind_requests_total[5m])",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ],
      "title": "Error Rate",
      "type": "stat",
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 20}, {"color": "red", "value": 50}]}}},
      "gridPos": {"h": 8, "w": 4, "x": 20, "y": 1},
      "id": 5,
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "metamind_active_queries", "legendFormat": "Active Queries", "refId": "A"}],
      "title": "Active Queries",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 10,
      "title": "Cache Performance",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "green", "value": 0.8}]}}
      },
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 10},
      "id": 11,
      "options": {"orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true},
      "targets": [
        {
          "expr": "rate(metamind_plan_cache_hits_total[5m]) / (rate(metamind_plan_cache_hits_total[5m]) + rate(metamind_plan_cache_misses_total[5m]))",
          "legendFormat": "Cache Hit Rate",
          "refId": "A"
        }
      ],
      "title": "Plan Cache Hit Rate",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 10, "x": 6, "y": 10},
      "id": 12,
      "targets": [
        {"expr": "metamind_plan_cache_entries", "legendFormat": "Cached Plans", "refId": "A"},
        {"expr": "rate(metamind_plan_cache_invalidations_total[1m]) * 60", "legendFormat": "Invalidations/min", "refId": "B"}
      ],
      "title": "Cache Entries & Invalidations",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 20,
      "title": "Optimization",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 19},
      "id": 21,
      "options": {"pieType": "donut", "legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {"expr": "sum by (tier) (rate(metamind_optimization_total[5m]))", "legendFormat": "Tier {{tier}}", "refId": "A"}
      ],
      "title": "Optimization Tier Distribution",
      "type": "piechart"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "gridPos": {"h": 8, "w": 16, "x": 8, "y": 19},
      "id": 22,
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(metamind_optimization_duration_ms_bucket[5m]))", "legendFormat": "Tier {{tier}} p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, rate(metamind_optimization_duration_ms_bucket[5m]))", "legendFormat": "Tier {{tier}} p95", "refId": "B"}
      ],
      "title": "Avg Optimization Latency by Tier",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "id": 30,
      "title": "Queue & Tenant",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 28},
      "id": 31,
      "targets": [{"expr": "metamind_queue_depth", "legendFormat": "Queue Depth", "refId": "A"}],
      "title": "Queue Depth Over Time",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 28},
      "id": 32,
      "targets": [
        {"expr": "sum by (tenant) (metamind_active_queries_queue)", "legendFormat": "{{tenant}}", "refId": "A"}
      ],
      "title": "Active Queries by Tenant",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 28},
      "id": 33,
      "targets": [
        {"expr": "histogram_quantile(0.95, rate(metamind_queue_wait_ms_bucket[5m]))", "legendFormat": "{{tenant}}", "refId": "A"}
      ],
      "title": "Queue Wait Time p95 by Tenant",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 36},
      "id": 40,
      "title": "Backend Usage",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 37},
      "id": 41,
      "options": {"xField": "backend"},
      "targets": [
        {"expr": "sum by (backend) (rate(metamind_queries_total[5m]))", "legendFormat": "{{backend}}", "refId": "A"}
      ],
      "title": "Backend Query Distribution",
      "type": "barchart"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 37},
      "id": 42,
      "targets": [
        {"expr": "histogram_quantile(0.95, rate(metamind_query_duration_ms_bucket[5m]))", "legendFormat": "{{backend}} p95", "refId": "A"}
      ],
      "title": "Backend Latency Comparison (p95)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["metamind", "operations"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "MetaMind — Operations Overview",
  "uid": "metamind-overview",
  "version": 1
}
